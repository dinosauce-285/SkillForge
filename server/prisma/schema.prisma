generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String?
  fullName            String           @map("full_name")
  role                Role             @default(STUDENT)
  provider            Provider         @default(LOCAL)
  isActive            Boolean          @default(false) @map("is_active")
  failedLoginAttempts Int              @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?        @map("locked_until")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  auditLogs           AuditLog[]       @relation("AdminLogs")
  certificates        Certificate[]
  courseProgresses    CourseProgress[]
  coursesCreated      Course[]         @relation("CourseInstructor")
  discussions         Discussion[]
  enrollments         Enrollment[]
  lessonProgresses    LessonProgress[]
  orders              Order[]
  quizAttempts        QuizAttempt[]
  reports             Report[]         @relation("ReportedBy")
  reviews             Review[]
  profile             UserProfile?
  wallet              Wallet?

  @@map("users")
}

model UserProfile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  avatarUrl     String?  @map("avatar_url")
  skills        String[]
  learningGoals String?  @map("learning_goals")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Category {
  id      String   @id @default(uuid())
  name    String   @unique
  courses Course[]

  @@map("categories")
}

model Course {
  id             String       @id @default(uuid())
  instructorId   String       @map("instructor_id")
  categoryId     String       @map("category_id")
  title          String
  subtitle       String?
  summary        String?      @db.Text
  thumbnailUrl   String?      @map("thumbnail_url")
  promoVideoUrl  String?      @map("promo_video_url")
  price          Decimal      @default(0) @db.Decimal(10, 2)
  isFree         Boolean      @default(false) @map("is_free")
  status         CourseStatus @default(DRAFT)
  level          CourseLevel @default(ALL_LEVELS)
  averageRating  Float       @default(0) @map("average_rating")
  studentCount   Int         @default(0) @map("student_count")
  tags           Tag[]
  enrollments    Enrollment[]
  orders         Order[]
  deletedAt      DateTime?    @map("deleted_at")
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  instructor     User         @relation("CourseInstructor", fields: [instructorId], references: [id])
  category       Category     @relation(fields: [categoryId], references: [id])
  chapters       Chapter[]
  courseProgresses CourseProgress[]
  statistics       CourseStatistic[]
  category         Category          @relation(fields: [categoryId], references: [id])
  instructor       User              @relation("CourseInstructor", fields: [instructorId], references: [id])
  enrollments      Enrollment[]
  orders           Order[]
  reviews          Review[]
  tags             Tag[]             @relation("CourseToTag")

  @@index([categoryId, level])
  @@index([title])
  @@map("courses")
}

model Chapter {
  id         String    @id @default(uuid())
  courseId   String    @map("course_id")
  title      String
  orderIndex Int       @default(0) @map("order_index")
  deletedAt  DateTime? @map("deleted_at")
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  @@map("chapters")
}

model Lesson {
  id               String           @id @default(uuid())
  chapterId        String           @map("chapter_id")
  title            String
  orderIndex       Int              @default(0) @map("order_index")
  deletedAt        DateTime?        @map("deleted_at")
  discussions      Discussion[]
  materials        LessonMaterial[]
  lessonProgresses LessonProgress[]
  chapter          Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quiz             Quiz?

  @@map("lessons")
}

model LessonMaterial {
  id       String         @id @default(uuid())
  lessonId String         @map("lesson_id")
  type     MaterialType
  fileUrl  String         @map("file_url")
  fileSize Int            @map("file_size")
  status   MaterialStatus @default(UPLOADING)
  lesson   Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_materials")
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique
  courses Course[] @relation("CourseToTag")

  @@map("tags")
}

model Enrollment {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  courseId   String           @map("course_id")
  status     EnrollmentStatus @default(ACTIVE)
  progress   Float            @default(0)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")
  course     Course           @relation(fields: [courseId], references: [id])
  user       User             @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Order {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  courseId    String       @map("course_id")
  amount      Decimal      @db.Decimal(10, 2)
  status      OrderStatus  @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  course      Course       @relation(fields: [courseId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  transaction Transaction?

  @@map("orders")
}

model Transaction {
  id                    String         @id @default(uuid())
  orderId               String         @unique @map("order_id")
  gateway               PaymentGateway
  externalTransactionId String?        @map("external_transaction_id")
  amount                Decimal        @db.Decimal(10, 2)
  createdAt             DateTime       @default(now()) @map("created_at")
  order                 Order          @relation(fields: [orderId], references: [id])

  @@map("transactions")
}

model Wallet {
  id               String              @id @default(uuid())
  userId           String              @unique @map("user_id")
  availableBalance Decimal             @default(0) @map("available_balance") @db.Decimal(10, 2)
  pendingBalance   Decimal             @default(0) @map("pending_balance") @db.Decimal(10, 2)
  user             User                @relation(fields: [userId], references: [id])
  withdrawals      WithdrawalRequest[]

  @@map("wallets")
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  walletId    String           @map("wallet_id")
  amount      Decimal          @db.Decimal(10, 2)
  bankInfo    String           @map("bank_info")
  status      WithdrawalStatus @default(PENDING)
  note        String?
  createdAt   DateTime         @default(now()) @map("created_at")
  processedAt DateTime?        @map("processed_at")
  wallet      Wallet           @relation(fields: [walletId], references: [id])

  @@map("withdrawal_requests")
}

model CourseProgress {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  courseId     String   @map("course_id")
  progress     Float    @default(0)
  isCompleted  Boolean  @default(false) @map("is_completed")
  lastAccessed DateTime @default(now()) @map("last_accessed")
  course       Course   @relation(fields: [courseId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@map("course_progresses")
}

model LessonProgress {
  id                  String  @id @default(uuid())
  userId              String  @map("user_id")
  lessonId            String  @map("lesson_id")
  isCompleted         Boolean @default(false) @map("is_completed")
  lastWatchedPosition Int     @default(0) @map("last_watched_position")
  lesson              Lesson  @relation(fields: [lessonId], references: [id])
  user                User    @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
  @@map("lesson_progresses")
}

model Quiz {
  id                 String        @id @default(uuid())
  lessonId           String        @unique @map("lesson_id")
  timeLimit          Int           @map("time_limit")
  passingScore       Float         @map("passing_score")
  randomizeQuestions Boolean       @default(false) @map("randomize_questions")
  questions          Question[]
  attempts           QuizAttempt[]
  lesson             Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model Question {
  id             String          @id @default(uuid())
  quizId         String          @map("quiz_id")
  content        String
  explanation    String?
  orderIndex     Int             @default(0) @map("order_index")
  choices        AnswerChoice[]
  quiz           Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  @@map("questions")
}

model AnswerChoice {
  id             String          @id @default(uuid())
  questionId     String          @map("question_id")
  content        String
  isCorrect      Boolean         @default(false) @map("is_correct")
  orderIndex     Int             @default(0) @map("order_index")
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  @@map("answer_choices")
}

model QuizAttempt {
  id        String          @id @default(uuid())
  studentId String          @map("student_id")
  quizId    String          @map("quiz_id")
  startTime DateTime        @default(now()) @map("start_time")
  endTime   DateTime?       @map("end_time")
  score     Float?
  isPassed  Boolean?        @map("is_passed")
  status    AttemptStatus   @default(IN_PROGRESS)
  quiz      Quiz            @relation(fields: [quizId], references: [id])
  student   User            @relation(fields: [studentId], references: [id])
  answers   StudentAnswer[]

  @@map("quiz_attempts")
}

model StudentAnswer {
  id               String        @id @default(uuid())
  attemptId        String        @map("attempt_id")
  questionId       String        @map("question_id")
  selectedChoiceId String?       @map("selected_choice_id")
  attempt          QuizAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question      @relation(fields: [questionId], references: [id])
  choice           AnswerChoice? @relation(fields: [selectedChoiceId], references: [id])

  @@unique([attemptId, questionId])
  @@map("student_answers")
}

model Discussion {
  id           String       @id @default(uuid())
  lessonId     String       @map("lesson_id")
  userId       String       @map("user_id")
  parentId     String?      @map("parent_id")
  content      String
  timestampTag Int?         @map("timestamp_tag")
  isPinned     Boolean      @default(false) @map("is_pinned")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  lesson       Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent       Discussion?  @relation("DiscussionReplies", fields: [parentId], references: [id])
  replies      Discussion[] @relation("DiscussionReplies")
  user         User         @relation(fields: [userId], references: [id])

  @@index([lessonId, parentId])
  @@map("discussions")
}

model Review {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  courseId        String   @map("course_id")
  rating          Int
  content         String
  instructorReply String?  @map("instructor_reply")
  helpfulCount    Int      @default(0) @map("helpful_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student         User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, courseId])
  @@map("reviews")
}

model Certificate {
  id              String   @id @default(uuid())
  certificateCode String   @unique @map("certificate_code")
  studentId       String   @map("student_id")
  courseId        String   @map("course_id")
  pdfUrl          String?  @map("pdf_url")
  imageUrl        String?  @map("image_url")
  issuedAt        DateTime @default(now()) @map("issued_at")
  course          Course   @relation(fields: [courseId], references: [id])
  student         User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, courseId])
  @@map("certificates")
}

model CourseStatistic {
  id                String   @id @default(uuid())
  courseId          String   @map("course_id")
  date              DateTime @db.Date
  revenue           Decimal  @default(0) @db.Decimal(10, 2)
  enrollmentCount   Int      @default(0) @map("enrollment_count")
  avgCompletionRate Float    @default(0) @map("avg_completion_rate")
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, date])
  @@index([date])
  @@map("course_statistics")
}

model Report {
  id         String       @id @default(uuid())
  reporterId String       @map("reporter_id")
  targetId   String       @map("target_id")
  type       ReportType
  reason     String
  status     ReportStatus @default(PENDING)
  adminNote  String?      @map("admin_note")
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")
  reporter   User         @relation("ReportedBy", fields: [reporterId], references: [id])

  @@map("reports")
}

model AuditLog {
  id         String     @id @default(uuid())
  adminId    String     @map("admin_id")
  action     ActionType
  entityType String     @map("entity_type")
  entityId   String     @map("entity_id")
  details    Json?
  createdAt  DateTime   @default(now()) @map("created_at")
  admin      User       @relation("AdminLogs", fields: [adminId], references: [id])

  @@map("audit_logs")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum CourseStatus {
  DRAFT
  PENDING
  PUBLISHED
}
